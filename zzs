<section class="stats" id="statistiky">
<div class="container">

<div class="section-title">
<h2>Statistiky Frakce</h2>
</div>

<div class="stats-grid">

<div class="stat">
<h3 id="vyjezdy">0</h3>
<p>Výjezdů</p>
</div>

<div class="stat">
